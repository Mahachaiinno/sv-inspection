<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>บันทึกข้อมูล SV – Quality Inspection</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
:root{
  --blue:#1F4E79;--blue-light:#E6F1FB;--blue-mid:#BDD7EE;
  --green:#375623;--green-light:#E2EFDA;
  --orange:#C55A11;--orange-light:#FCE4D6;
  --purple:#7030A0;--purple-light:#EAE0F0;
  --gold:#7F6000;--gold-light:#FFF2CC;
  --bg:#F4F6F9;--surface:#fff;--border:#DDE3EC;
  --text:#1A2233;--text-sec:#5A6478;--text-ter:#9AA3B2;
  --radius:10px;--shadow:0 2px 12px rgba(31,78,121,.08);
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Sarabun',sans-serif;background:var(--bg);color:var(--text);font-size:14px;line-height:1.5}
/* Topbar */
.topbar{background:var(--blue);color:#fff;padding:0 20px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;min-height:52px;position:sticky;top:0;z-index:100;box-shadow:0 2px 8px rgba(0,0,0,.18)}
.topbar-title{font-size:15px;font-weight:700;display:flex;align-items:center;gap:8px;letter-spacing:.3px}
.topbar-right{display:flex;align-items:center;gap:8px;flex-wrap:wrap;padding:8px 0}
.tab-btn{background:transparent;border:none;color:rgba(255,255,255,.65);padding:6px 11px;border-radius:7px;cursor:pointer;font-size:12px;font-weight:600;font-family:'Sarabun',sans-serif;transition:all .15s;display:flex;align-items:center;gap:4px;letter-spacing:.2px}
.tab-btn.active{background:rgba(255,255,255,.18);color:#fff}
.tab-btn:hover:not(.active){background:rgba(255,255,255,.1);color:#fff}
.sync-btn{display:flex;align-items:center;gap:5px;padding:6px 13px;border-radius:7px;border:1.5px solid rgba(255,255,255,.35);background:transparent;color:#fff;font-size:12px;font-weight:600;font-family:'Sarabun',sans-serif;cursor:pointer;transition:all .15s}
.sync-btn:hover{background:rgba(255,255,255,.15)}
.sync-btn:disabled{opacity:.45;pointer-events:none}
.conn-pill{display:flex;align-items:center;gap:6px;padding:5px 11px;border-radius:20px;font-size:11px;font-weight:600;background:rgba(255,255,255,.1);color:rgba(255,255,255,.85)}
.dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.dot-ok{background:#4ade80}.dot-err{background:#f87171}.dot-spin{background:#facc15;animation:blink 1s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
/* Layout */
.page{display:none;padding:18px;max-width:1280px;margin:0 auto}
.page.active{display:block}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;margin-bottom:14px;box-shadow:var(--shadow)}
/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:10px;margin-bottom:14px}
.kpi{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:13px 15px;box-shadow:var(--shadow)}
.kpi-label{font-size:11px;color:var(--text-sec);font-weight:600;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}
.kpi-val{font-size:26px;font-weight:700;font-family:'IBM Plex Mono',monospace}
.kpi-val.blue{color:var(--blue)}.kpi-val.pass{color:var(--green)}.kpi-val.fail{color:var(--orange)}.kpi-val.hold{color:var(--gold)}.kpi-val.pct{color:var(--purple)}
/* Form */
.form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px}
.field{display:flex;flex-direction:column;gap:5px}
.field label{font-size:11px;color:var(--text-sec);font-weight:700;text-transform:uppercase;letter-spacing:.4px}
.field input,.field select,.field textarea{width:100%;padding:8px 11px;border:1.5px solid var(--border);border-radius:8px;background:var(--surface);color:var(--text);font-size:13px;font-family:'Sarabun',sans-serif;transition:border-color .15s}
.field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 3px rgba(31,78,121,.1)}
.field textarea{resize:vertical;min-height:50px}
.field.full{grid-column:1/-1}
.section-hdr{font-size:11px;font-weight:700;color:var(--blue);margin:0 0 12px;padding-bottom:7px;border-bottom:2px solid var(--blue-light);display:flex;align-items:center;gap:6px;text-transform:uppercase;letter-spacing:.5px}
/* Buttons */
.btn-row{display:flex;gap:8px;justify-content:flex-end;margin-top:12px}
.btn{padding:8px 18px;border-radius:8px;border:1.5px solid var(--border);background:transparent;cursor:pointer;font-size:13px;font-weight:600;font-family:'Sarabun',sans-serif;color:var(--text);transition:all .15s;display:inline-flex;align-items:center;gap:6px}
.btn:hover{background:var(--bg)}
.btn.primary{background:var(--blue);color:#fff;border-color:var(--blue)}
.btn.primary:hover{background:#163a5e}
.btn.primary:disabled{opacity:.45;pointer-events:none}
.btn.success{background:var(--green);color:#fff;border-color:var(--green)}
.btn.success:hover{background:#2a4019}
.btn.sm{padding:4px 10px;font-size:11px}
.btn.danger{border-color:#fca5a5;color:var(--orange)}
.btn.danger:hover{background:var(--orange-light)}
/* Badge */
.badge{display:inline-block;padding:3px 9px;border-radius:5px;font-size:11px;font-weight:700;letter-spacing:.3px}
.badge.pass{background:var(--green-light);color:var(--green)}
.badge.fail{background:var(--orange-light);color:var(--orange)}
.badge.hold{background:var(--gold-light);color:var(--gold)}
/* Check buttons */
.check-group{display:flex;gap:8px;flex-wrap:wrap}
.check-opt{flex:1;min-width:85px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;padding:11px 8px;border:2px solid var(--border);border-radius:10px;cursor:pointer;background:var(--surface);transition:all .15s;font-size:12px;font-weight:600;color:var(--text-sec);font-family:'Sarabun',sans-serif}
.check-opt:hover{border-color:var(--blue-mid);background:var(--blue-light)}
.check-opt.sel-ck{border-color:var(--blue);background:var(--blue-light);color:var(--blue)}
.check-opt.sel-rc{border-color:var(--purple);background:var(--purple-light);color:var(--purple)}
.check-opt.sel-none{border:2px dashed var(--border);background:var(--bg);color:var(--text-ter)}
/* Prod table */
.prod-wrap{overflow-x:auto;margin-bottom:4px}
.prod-table{width:100%;border-collapse:collapse;font-size:12px;min-width:720px}
.prod-table th{padding:8px 10px;text-align:center;font-weight:700;font-size:10px;color:#fff;border:1px solid rgba(255,255,255,.2);letter-spacing:.4px;text-transform:uppercase}
.th-b{background:var(--blue)}.th-g{background:var(--green)}
.prod-table td{padding:4px 5px;border:1px solid var(--border)}
.prod-table td select,.prod-table td input{width:100%;padding:5px 6px;border:none;border-radius:5px;background:var(--bg);color:var(--text);font-size:12px;font-family:'Sarabun',sans-serif;transition:background .1s}
.prod-table td select:focus,.prod-table td input:focus{outline:1.5px solid var(--blue);background:#fff}
.prod-table tbody tr:nth-child(even) td{background:#F8FAFC}
.prod-table tbody tr:nth-child(odd) td{background:#fff}
.spec-td{text-align:center;font-size:11px;font-family:'IBM Plex Mono',monospace;color:var(--text-sec);background:#F8FAFC!important}
.res-pass{background:var(--green-light)!important;color:var(--green);font-weight:700;text-align:center;font-family:'IBM Plex Mono',monospace}
.res-fail{background:var(--orange-light)!important;color:var(--orange);font-weight:700;text-align:center;font-family:'IBM Plex Mono',monospace}
.res-blank{text-align:center;color:var(--text-ter)}
.del-row-btn{padding:3px 7px;border:none;background:transparent;cursor:pointer;color:var(--text-ter);font-size:13px;border-radius:5px;transition:all .15s}
.del-row-btn:hover{color:var(--orange);background:var(--orange-light)}
.add-row-btn{display:inline-flex;align-items:center;gap:6px;padding:6px 13px;border:2px dashed var(--border);border-radius:8px;background:transparent;cursor:pointer;font-size:12px;font-weight:600;font-family:'Sarabun',sans-serif;color:var(--text-sec);margin-top:8px;transition:all .15s}
.add-row-btn:hover{border-color:var(--blue);color:var(--blue);background:var(--blue-light)}
/* Rec table */
.rec-table{width:100%;border-collapse:collapse;font-size:12px}
.rec-table th{padding:8px 10px;text-align:left;font-weight:700;font-size:10px;color:var(--text-sec);border-bottom:2px solid var(--border);background:#F8FAFC;white-space:nowrap;text-transform:uppercase;letter-spacing:.4px}
.rec-table td{padding:7px 10px;border-bottom:1px solid var(--border);vertical-align:middle}
.rec-table tr:last-child td{border-bottom:none}
.rec-table tr:hover td{background:#F8FAFC}
.shift-p1{display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:700;background:var(--blue-light);color:var(--blue)}
.shift-p2{display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:700;background:var(--gold-light);color:var(--gold)}
.shift-p3{display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:700;background:var(--purple-light);color:var(--purple)}
.ck-ck{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:4px;font-size:10px;font-weight:700;background:var(--blue-light);color:var(--blue)}
.ck-rc{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:4px;font-size:10px;font-weight:700;background:var(--purple-light);color:var(--purple)}
/* Sampling dropdown */
.samp-dd{position:relative}
.samp-trigger{width:100%;padding:8px 11px;border:1.5px solid var(--border);border-radius:8px;background:var(--surface);color:var(--text);font-size:13px;font-family:'Sarabun',sans-serif;cursor:pointer;text-align:left;display:flex;align-items:center;justify-content:space-between;transition:border-color .15s}
.samp-trigger:hover{border-color:var(--blue)}
.samp-trigger.has-val{border-color:var(--blue);color:var(--blue);background:var(--blue-light);font-weight:600}
.samp-panel{position:absolute;top:calc(100% + 4px);left:0;right:0;background:#fff;border:1.5px solid var(--border);border-radius:10px;box-shadow:0 8px 24px rgba(31,78,121,.14);z-index:500;max-height:240px;overflow-y:auto;display:none}
.samp-panel.open{display:block}
.samp-opt{display:flex;align-items:center;gap:8px;padding:8px 12px;cursor:pointer;transition:background .1s}
.samp-opt:hover,.samp-opt.selected{background:var(--blue-light)}
.samp-opt.selected{color:var(--blue);font-weight:600}
.samp-num{font-size:10px;color:var(--text-ter);min-width:18px;font-family:'IBM Plex Mono',monospace;font-weight:600}
.samp-opt.selected .samp-num{color:var(--blue)}
/* SPEC */
.spec-mgr{width:100%;border-collapse:collapse;font-size:13px}
.spec-mgr th{padding:9px 12px;background:var(--blue);color:#fff;font-weight:700;font-size:11px;text-align:left;text-transform:uppercase;letter-spacing:.4px}
.spec-mgr td{padding:8px 11px;border-bottom:1px solid var(--border)}
.spec-mgr tr:last-child td{border-bottom:none}
.spec-mgr tr:hover td{background:#F8FAFC}
.sinput{padding:6px 9px;border:1.5px solid var(--border);border-radius:7px;background:#fff;color:var(--text);font-size:12px;font-family:'IBM Plex Mono',monospace;width:80px;text-align:center;transition:border-color .15s}
.sinput:focus{outline:none;border-color:var(--blue)}
/* Dashboard bars */
.result-row{display:flex;align-items:center;padding:7px 0;border-bottom:1px solid var(--border);gap:9px}
.result-row:last-child{border:none}
.bar-wrap{height:7px;background:var(--bg);border-radius:4px;overflow:hidden;flex:1}
.bar-fill{height:100%;border-radius:4px;background:var(--green)}
.trend{display:flex;gap:5px;flex-wrap:wrap}
.trend-dot{width:11px;height:11px;border-radius:50%;flex-shrink:0;cursor:default;transition:transform .1s}
.trend-dot:hover{transform:scale(1.4)}
/* Toast */
.toast{position:fixed;bottom:18px;right:18px;color:#fff;padding:10px 16px;border-radius:9px;font-size:13px;font-weight:600;font-family:'Sarabun',sans-serif;opacity:0;transition:opacity .25s;pointer-events:none;z-index:9999;display:flex;align-items:center;gap:7px;max-width:320px;box-shadow:0 4px 20px rgba(0,0,0,.2)}
.toast.show{opacity:1}
.toast.ok{background:var(--green)}.toast.err{background:var(--orange)}.toast.info{background:var(--blue)}
/* Search row */
.search-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px}
.search-title{font-size:13px;font-weight:700;color:var(--text-sec)}
.search-controls{display:flex;gap:7px;flex-wrap:wrap}
.search-input{font-size:12px;padding:7px 11px;border:1.5px solid var(--border);border-radius:8px;background:#fff;color:var(--text);font-family:'Sarabun',sans-serif;width:175px;transition:border-color .15s}
.search-input:focus{outline:none;border-color:var(--blue)}
.filter-sel{font-size:12px;padding:7px 11px;border:1.5px solid var(--border);border-radius:8px;background:#fff;color:var(--text);font-family:'Sarabun',sans-serif;cursor:pointer}
.empty{text-align:center;padding:32px;color:var(--text-ter);font-size:13px}
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-title">
    <i class="ti ti-clipboard-check"></i> บันทึกข้อมูล SV
  </div>
  <div class="topbar-right">
    <div class="conn-pill"><span class="dot dot-spin" id="cdot"></span><span id="ctxt">กำลังเชื่อมต่อ...</span></div>
    <button class="sync-btn" id="syncbtn" onclick="syncAll()" disabled>
      <i class="ti ti-refresh"></i> Sync
    </button>
    <button class="tab-btn active" onclick="showPage('form',this)"><i class="ti ti-plus"></i> บันทึก</button>
    <button class="tab-btn" onclick="showPage('records',this)"><i class="ti ti-list"></i> รายการ</button>
    <button class="tab-btn" onclick="showPage('dash',this)"><i class="ti ti-chart-bar"></i> Dashboard</button>
    <button class="tab-btn" onclick="showPage('spec',this)"><i class="ti ti-ruler"></i> SPEC</button>
  </div>
</div>

<!-- ═══ PAGE: FORM ═══ -->
<div id="page-form" class="page active">
  <div class="card">
    <div class="section-hdr"><i class="ti ti-info-circle"></i> ข้อมูลทั่วไป</div>
    <div class="form-grid">
      <div class="field"><label>วันที่ *</label><input type="date" id="f-date"></div>
      <div class="field"><label>เวลา *</label><input type="time" id="f-time"></div>
      <div class="field">
        <label>Inspector *</label>
        <select id="f-inspector">
          <option value="">-- เลือก Inspector --</option>
          <option>Inspector 1</option><option>Inspector 2</option><option>Inspector 3</option>
          <option>Inspector 4</option><option>Inspector 5</option><option>Inspector 6</option><option>Inspector 7</option>
        </select>
      </div>
      <div class="field">
        <label>Shift *</label>
        <select id="f-shift">
          <option value="">-- เลือก Shift --</option>
          <option>P1</option><option>P2</option><option>P3</option>
        </select>
      </div>
      <div class="field">
        <label>Sampling *</label>
        <div class="samp-dd" id="samp-dd">
          <button type="button" class="samp-trigger" id="samp-trigger" onclick="toggleSampPanel()">
            <span id="samp-lbl" style="color:var(--text-ter)">-- เลือก Sampling --</span>
            <i class="ti ti-chevron-down" style="font-size:13px;color:var(--text-ter)"></i>
          </button>
          <div class="samp-panel" id="samp-panel"></div>
        </div>
        <input type="hidden" id="f-sampling">
      </div>
      <div class="field full">
        <label>Check</label>
        <div class="check-group">
          <button class="check-opt" id="chk-ck" onclick="selCheck('ตรวจสอบ')" type="button">
            <i class="ti ti-circle-check" style="font-size:22px;color:var(--blue)"></i>ตรวจสอบ
          </button>
          <button class="check-opt" id="chk-rc" onclick="selCheck('Recheck')" type="button">
            <i class="ti ti-refresh-alert" style="font-size:22px;color:var(--purple)"></i>Recheck
          </button>
          <button class="check-opt sel-none" id="chk-none" onclick="selCheck('')" type="button" style="max-width:110px">
            <i class="ti ti-minus" style="font-size:22px;color:var(--text-ter)"></i>ไม่ระบุ
          </button>
        </div>
      </div>
      <div class="field full"><label>Remark</label><textarea id="f-remark" placeholder="หมายเหตุ (ถ้ามี)"></textarea></div>
    </div>
  </div>

  <div class="card">
    <div class="section-hdr"><i class="ti ti-table"></i> ตารางการผลิต & ผลการตรวจ</div>
    <div class="prod-wrap">
      <table class="prod-table">
        <thead>
          <tr>
            <th class="th-b" style="width:26px"></th>
            <th class="th-b">LINE</th>
            <th class="th-b">Main Formula</th>
            <th class="th-b">Sub Formula</th>
            <th class="th-b">Feed Code</th>
            <th class="th-b">Die Size</th>
            <th class="th-b">SV</th>
            <th class="th-g">SPEC Min</th>
            <th class="th-g">SPEC Max</th>
            <th class="th-b">ผล</th>
          </tr>
        </thead>
        <tbody id="prod-tbody"></tbody>
      </table>
    </div>
    <button class="add-row-btn" onclick="addRow()" type="button"><i class="ti ti-plus"></i> เพิ่มแถว</button>
    <div class="btn-row">
      <button class="btn" onclick="clearForm()"><i class="ti ti-refresh"></i> ล้างข้อมูล</button>
      <button class="btn primary" id="save-btn" onclick="saveRecord()"><i class="ti ti-device-floppy"></i> บันทึก → Google Sheet</button>
    </div>
  </div>
</div>

<!-- ═══ PAGE: RECORDS ═══ -->
<div id="page-records" class="page">
  <div class="card">
    <div class="search-row">
      <div class="search-title">รายการทั้งหมด (<span id="rec-count">0</span> รายการ)</div>
      <div class="search-controls">
        <input class="search-input" type="text" id="search" placeholder="ค้นหา Inspector / Main Formula..." oninput="renderTable()">
        <select class="filter-sel" id="filter-result" onchange="renderTable()">
          <option value="">ทั้งหมด</option><option>Pass</option><option>Fail</option><option>Hold</option>
        </select>
      </div>
    </div>
    <div style="overflow-x:auto">
      <table class="rec-table">
        <thead><tr>
          <th>#</th><th>วันที่</th><th>เวลา</th><th>Inspector</th><th>Shift</th><th>Check</th>
          <th>Sampling</th><th>LINE</th><th>Main</th><th>Sub</th>
          <th>Feed Code</th><th>Die Size</th><th>SV</th><th>SPEC</th><th>ผล</th><th></th>
        </tr></thead>
        <tbody id="rec-body"></tbody>
      </table>
      <div id="rec-empty" class="empty" style="display:none">
        <i class="ti ti-database-off" style="font-size:32px;display:block;margin-bottom:9px"></i>
        ยังไม่มีข้อมูล — กด Sync เพื่อดึงจาก Google Sheet
      </div>
    </div>
  </div>
</div>

<!-- ═══ PAGE: DASHBOARD ═══ -->
<div id="page-dash" class="page">

  <!-- Filter Bar -->
  <div class="card" style="margin-bottom:14px">
    <div class="section-hdr"><i class="ti ti-filter"></i> กรองข้อมูล</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;align-items:end">
      <div class="field">
        <label>วันที่เริ่มต้น</label>
        <input type="date" id="df-from" onchange="renderDash()">
      </div>
      <div class="field">
        <label>วันที่สิ้นสุด</label>
        <input type="date" id="df-to" onchange="renderDash()">
      </div>
      <div class="field">
        <label>Main Formula</label>
        <select id="df-main" onchange="renderDash()">
          <option value="">ทั้งหมด</option>
          <option>701</option><option>901</option><option>POLY</option>
          <option>MS3618</option><option>MS9123</option><option>TNT</option>
          <option>BROODS</option><option>NF</option>
        </select>
      </div>
      <div class="field">
        <label>Sub Formula</label>
        <select id="df-sub" onchange="renderDash()">
          <option value="">ทั้งหมด</option>
          <option>P</option><option>S</option><option>G</option><option>NK</option><option>MY</option>
        </select>
      </div>
      <div class="field">
        <label>Shift</label>
        <select id="df-shift" onchange="renderDash()">
          <option value="">ทั้งหมด</option>
          <option>P1</option><option>P2</option><option>P3</option>
        </select>
      </div>
      <div class="field">
        <label>LINE</label>
        <select id="df-line" onchange="renderDash()">
          <option value="">ทั้งหมด</option>
          <option>L1</option><option>L2</option><option>L3</option><option>L4</option>
          <option>L5</option><option>L6</option><option>L7</option><option>L8</option>
        </select>
