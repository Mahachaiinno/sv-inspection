// Toast
function toast(msg,type='info'){
  const t=document.getElementById('toast-el');
  t.textContent=msg;t.className='toast '+type+' show';
  clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),3000);
}

// Prod table
function mOpts(){return'<option value="">—</option>'+MAIN_FORMULAS.map(f=>`<option>${f}</option>`).join('');}
function sOpts(){return'<option value="">None</option><option>P</option><option>S</option><option>G</option><option>NK</option><option>MY</option>';}
function lOpts(){return'<option value="">—</option>'+LINES.map(l=>`<option>${l}</option>`).join('');}
function dOpts(){return'<option value="">—</option><option>1.0</option><option>1.2</option><option>1.4</option><option>1.7</option><option>2.0</option><option>2.3</option>';}
function makeRow(id){
  return`<tr id="row-${id}">
    <td style="text-align:center"><button class="del-row-btn" onclick="delRow(${id})">✕</button></td>
    <td><select class="r-line">${lOpts()}</select></td>
    <td><select class="r-main" onchange="onMC(${id})">${mOpts()}</select></td>
    <td><select class="r-sub" onchange="calcRes(${id})">${sOpts()}</select></td>
    <td><input class="r-feed" type="text" placeholder="Feed Code"></td>
    <td><select class="r-die">${dOpts()}</select></td>
    <td><input class="r-sv" type="number" placeholder="0.00" step="0.01" oninput="calcRes(${id})" style="font-family:'IBM Plex Mono',monospace;text-align:center"></td>
    <td class="spec-td" id="smn-${id}">—</td>
    <td class="spec-td" id="smx-${id}">—</td>
    <td class="res-blank" id="res-${id}">—</td>
  </tr>`;
}
function addRow(){rowId++;document.getElementById('prod-tbody').insertAdjacentHTML('beforeend',makeRow(rowId));}
function delRow(id){document.getElementById('row-'+id)?.remove();if(!document.getElementById('prod-tbody').children.length)addRow();}
function onMC(id){updSpec(id);calcRes(id);}
function updSpec(id){
  const row=document.getElementById('row-'+id);
  const sp=getSpec(row.querySelector('.r-main').value,row.querySelector('.r-sub').value);
  document.getElementById('smn-'+id).textContent=sp&&(sp.min||sp.max)?sp.min:'—';
  document.getElementById('smx-'+id).textContent=sp&&(sp.min||sp.max)?sp.max:'—';
}
function calcRes(id){
  updSpec(id);const row=document.getElementById('row-'+id);
  const sv=parseFloat(row.querySelector('.r-sv').value);
  const sp=getSpec(row.querySelector('.r-main').value,row.querySelector('.r-sub').value);
  const el=document.getElementById('res-'+id);
  if(!sp||isNaN(sv)||(!sp.min&&!sp.max)){el.className='res-blank';el.textContent='—';return;}
  const ok=sv>=sp.min&&sv<=sp.max;el.className=ok?'res-pass':'res-fail';el.textContent=ok?'Pass ✓':'Fail ✗';
}
function getRows(){
  return Array.from(document.getElementById('prod-tbody').rows).map(row=>{
    const main=row.querySelector('.r-main').value,sub=row.querySelector('.r-sub').value;
    const sv=row.querySelector('.r-sv').value,svN=parseFloat(sv);
    const sp=getSpec(main,sub);let result='';
    if(sp&&!isNaN(svN)&&(sp.min||sp.max))result=svN>=sp.min&&svN<=sp.max?'Pass':'Fail';
    return{line:row.querySelector('.r-line').value,main,sub,feedcode:row.querySelector('.r-feed').value,diesize:row.querySelector('.r-die').value,sv,specMin:sp?sp.min:'',specMax:sp?sp.max:'',result};
  }).filter(r=>r.line||r.main||r.sv);
}
function clearProd(){document.getElementById('prod-tbody').innerHTML='';rowId=0;addRow();}
function clearForm(){
  ['f-inspector','f-shift'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('f-remark').value='';selCheck('');clearSamp();clearProd();
  const n=nowDT();document.getElementById('f-date').value=n.date;document.getElementById('f-time').value=n.time;
}
async function saveRecord(){
  if(!fget('f-inspector')){toast('กรุณาเลือก Inspector','err');return;}
  if(!fget('f-shift')){toast('กรุณาเลือก Shift','err');return;}
  if(!selSampVal){toast('กรุณาเลือก Sampling','err');return;}
  const rows=getRows();if(!rows.length){toast('กรุณากรอกข้อมูลอย่างน้อย 1 แถว','err');return;}
  const rec={id:Date.now(),date:fget('f-date'),time:fget('f-time'),inspector:fget('f-inspector'),shift:fget('f-shift'),check:selCheckVal,sampling:selSampVal,remark:fget('f-remark'),rows};
  records.unshift(rec);saveLocal();
  const btn=document.getElementById('save-btn');btn.disabled=true;btn.innerHTML='<i class="ti ti-loader-2"></i> กำลังบันทึก...';
  try{await gsCall({action:'save',data:rec});toast('บันทึก Google Sheet สำเร็จ ✓ ('+rows.length+' แถว)','ok');setConn('ok','Google Sheet พร้อมใช้งาน');}
  catch(e){toast('บันทึก Local แล้ว — Sheet: '+e.message,'err');setConn('err','Sheet error');}
  btn.disabled=false;btn.innerHTML='<i class="ti ti-device-floppy"></i> บันทึก → Google Sheet';
  clearForm();
}

// Records
function bHtml(r){if(!r)return'—';return`<span class="badge ${r.toLowerCase()}">${r}</span>`;}
function sBadge(s){if(!s)return'—';const c=s==='P1'?'shift-p1':s==='P2'?'shift-p2':'shift-p3';return`<span class="${c}">${s}</span>`;}
function cBadge(c){if(!c)return'—';if(c==='ตรวจสอบ')return`<span class="ck-ck"><i class="ti ti-circle-check"></i> ตรวจสอบ</span>`;if(c==='Recheck')return`<span class="ck-rc"><i class="ti ti-refresh-alert"></i> Recheck</span>`;return c;}
function renderTable(){
  const q=(document.getElementById('search').value||'').toLowerCase();
  const rf=document.getElementById('filter-result').value;
  const flat=[];
  records.forEach(rec=>{
    (rec.rows||[]).forEach(row=>{
      if(rf&&row.result!==rf)return;
      if(q&&!(rec.inspector+(row.main||'')+rec.sampling).toLowerCase().includes(q))return;
      flat.push({rec,row});
    });
    if(!(rec.rows||[]).length&&!rf&&(!q||(rec.inspector+rec.sampling).toLowerCase().includes(q)))flat.push({rec,row:{}});
  });
  document.getElementById('rec-count').textContent=flat.length;
  const tbody=document.getElementById('rec-body');
  if(!flat.length){tbody.innerHTML='';document.getElementById('rec-empty').style.display='block';return;}
  document.getElementById('rec-empty').style.display='none';
  let html='',prevId=null;
  flat.forEach(({rec,row},i)=>{
    const isNew=prevId!==rec.id;
    const spec=(row.specMin!==undefined&&(row.specMin||row.specMax))?`${row.specMin}–${row.specMax}`:'—';
    html+=`<tr>
      <td style="color:var(--text-ter);font-size:10px;text-align:center">${flat.length-i}</td>
      <td>${isNew?rec.date:''}</td><td>${isNew?rec.time:''}</td>
      <td style="font-weight:700">${isNew?rec.inspector:''}</td>
      <td>${isNew?sBadge(rec.shift):''}</td>
      <td>${isNew?cBadge(rec.check):''}</td>
      <td style="font-size:11px">${isNew?(rec.sampling||'—'):''}</td>
      <td>${row.line||'—'}</td>
      <td style="font-weight:700">${row.main||'—'}</td>
      <td style="color:var(--text-sec)">${row.sub||'—'}</td>
      <td style="font-family:'IBM Plex Mono',monospace;font-size:11px">${row.feedcode||'—'}</td>
      <td style="font-size:11px">${row.diesize||'—'}</td>
      <td style="font-family:'IBM Plex Mono',monospace;font-weight:700">${row.sv||'—'}</td>
      <td style="font-family:'IBM Plex Mono',monospace;font-size:11px">${spec}</td>
      <td>${bHtml(row.result)}</td>
      <td>${isNew?`<button class="btn sm danger" onclick="delRec(${rec.id})"><i class="ti ti-trash"></i></button>`:''}</td>
    </tr>`;
    if(i<flat.length-1&&flat[i+1].rec.id!==rec.id)html+=`<tr><td colspan="16" style="padding:0;height:3px;background:var(--bg)"></td></tr>`;
    prevId=rec.id;
  });
  tbody.innerHTML=html;
}
async function delRec(id){
  records=records.filter(r=>r.id!==id);saveLocal();renderTable();
  try{await gsCall({action:'delete',id:String(id)});toast('ลบจาก Google Sheet แล้ว','ok');}
  catch(e){toast('ลบ Local แล้ว (Sheet: '+e.message+')','err');}
}

// Dashboard
function getDashFilter(){
  return{
    from: document.getElementById('df-from').value,
    to:   document.getElementById('df-to').value,
    main: document.getElementById('df-main').value,
    sub:  document.getElementById('df-sub').value,
    shift:document.getElementById('df-shift').value,
    line: document.getElementById('df-line').value,
  };
}
function clearDashFilter(){
  ['df-from','df-to','df-main','df-sub','df-shift','df-line'].forEach(id=>document.getElementById(id).value='');
  renderDash();
}
function filteredData(){
  const f=getDashFilter();
  return records.filter(rec=>{
    if(f.shift&&rec.shift!==f.shift)return false;
    if(f.from&&rec.date<f.from)return false;
    if(f.to&&rec.date>f.to)return false;
    return true;
  }).map(rec=>({
    ...rec,
    rows:(rec.rows||[]).filter(row=>{
      if(f.main&&row.main!==f.main)return false;
      if(f.sub&&row.sub!==f.sub)return false;
      if(f.line&&row.line!==f.line)return false;
      return true;
    })
  })).filter(rec=>rec.rows.length);
}
function sumRows(keys,keyFn,data){
  if(!data.length)return'<div class="empty" style="padding:12px">ไม่มีข้อมูล</div>';
  const total=data.length;
  return keys.map(k=>{
    const rs=data.filter(r=>keyFn(r)===k);if(!rs.length)return'';
    const rl=rs.flatMap(r=>r.rows||[]);
    const pass=rl.filter(r=>r.result==='Pass').length;
    const pPct=rl.length?Math.round(pass/rl.length*100):0;
    const w=Math.round(rs.length/total*100);
    return`<div class="result-row"><span style="font-size:12px;font-weight:600;min-width:75px;word-break:break-all">${k}</span><div class="bar-wrap"><div class="bar-fill" style="width:${w}%"></div></div><span style="font-size:11px;color:var(--text-sec);white-space:nowrap;min-width:68px;text-align:right">${rs.length} btc (${pPct}%P)</span></div>`;
  }).filter(Boolean).join('');
}
function renderDash(){
  const data=filteredData();
  const ar=data.flatMap(r=>r.rows||[]);
  const total=ar.length,pass=ar.filter(r=>r.result==='Pass').length,fail=ar.filter(r=>r.result==='Fail').length,hold=ar.filter(r=>r.result==='Hold').length;
  document.getElementById('d-total').textContent=total;
  document.getElementById('d-pass').textContent=pass;
  document.getElementById('d-fail').textContent=fail;
  document.getElementById('d-hold').textContent=hold;
  document.getElementById('d-pct').textContent=total?((pass/total)*100).toFixed(1)+'%':'0%';
  const svs=ar.map(r=>parseFloat(r.sv)).filter(v=>!isNaN(v)&&v>0);
  document.getElementById('d-avg').textContent=svs.length?(svs.reduce((a,b)=>a+b,0)/svs.length).toFixed(2):'—';
  // label
  const f=getDashFilter();
  const parts=[];
  if(f.from||f.to)parts.push((f.from||'...')+' ถึง '+(f.to||'...'));
  if(f.main)parts.push('Main: '+f.main);
  if(f.sub)parts.push('Sub: '+f.sub);
  if(f.shift)parts.push('Shift: '+f.shift);
  if(f.line)parts.push('LINE: '+f.line);
  document.getElementById('df-count-label').textContent=parts.length?parts.join(' | '):'ทั้งหมด';
  document.getElementById('d-shift').innerHTML=sumRows(['P1','P2','P3'],r=>r.shift,data);
  document.getElementById('d-insp').innerHTML=sumRows(INSPECTORS,r=>r.inspector,data);
  document.getElementById('d-samp').innerHTML=sumRows(SAMP_LIST.map(s=>s.l),r=>r.sampling,data);
  // Line chart with trendline
  drawSVChart(ar);
}

// ── SV Line Chart with Trendline ──────────────────────────────
function drawSVChart(ar){
  const canvas=document.getElementById('sv-chart');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const pts=ar.map((r,i)=>({i,sv:parseFloat(r.sv),smin:parseFloat(r.specMin),smax:parseFloat(r.specMax),result:r.result,label:(r.main||'')+(r.sub?' '+r.sub:''),date:r.date||''})).filter(p=>!isNaN(p.sv));

  // sizing
  const dpr=window.devicePixelRatio||1;
  const W=canvas.parentElement.clientWidth-32||600;
  const H=260;
  canvas.width=W*dpr;canvas.height=H*dpr;
  canvas.style.width=W+'px';canvas.style.height=H+'px';
  ctx.scale(dpr,dpr);

  const PAD={top:20,right:20,bottom:48,left:52};
  const cW=W-PAD.left-PAD.right;
  const cH=H-PAD.top-PAD.bottom;

  ctx.clearRect(0,0,W,H);

  if(!pts.length){
    ctx.fillStyle='#9AA3B2';ctx.font='13px Sarabun,sans-serif';ctx.textAlign='center';
    ctx.fillText('ไม่มีข้อมูล SV',W/2,H/2);return;
  }

  // value range
  const svVals=pts.map(p=>p.sv);
  const smins=pts.map(p=>p.smin).filter(v=>!isNaN(v)&&v>0);
  const smaxs=pts.map(p=>p.smax).filter(v=>!isNaN(v)&&v>0);
  const allVals=[...svVals,...smins,...smaxs];
  let vmin=Math.min(...allVals),vmax=Math.max(...allVals);
  const pad=(vmax-vmin)*0.15||10;
  vmin=Math.floor(vmin-pad);vmax=Math.ceil(vmax+pad);

  const xOf=i=>PAD.left+(i/(pts.length-1||1))*cW;
  const yOf=v=>PAD.top+cH-(((v-vmin)/(vmax-vmin))*cH);

  // CSS vars
  const st=getComputedStyle(document.documentElement);
  const C_BLUE='#1F4E79',C_GREEN='#375623',C_ORANGE='#C55A11',C_GRID='#DDE3EC',C_TEXT='#5A6478';

  // Grid lines + Y labels
  const steps=6;
  ctx.font='11px IBM Plex Mono,monospace';ctx.fillStyle=C_TEXT;ctx.textAlign='right';
  for(let i=0;i<=steps;i++){
    const v=vmin+((vmax-vmin)/steps)*i;
    const y=yOf(v);
    ctx.strokeStyle=C_GRID;ctx.lineWidth=1;ctx.setLineDash([3,3]);
    ctx.beginPath();ctx.moveTo(PAD.left,y);ctx.lineTo(PAD.left+cW,y);ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillText(Math.round(v),PAD.left-6,y+4);
  }

  // SPEC Min/Max bands (from first spec found)
  const specMin=smins.length?smins[0]:null;
  const specMax=smaxs.length?smaxs[0]:null;
  if(specMin!==null&&specMax!==null){
    const yMn=yOf(specMin),yMx=yOf(specMax);
    // band fill
    ctx.fillStyle='rgba(55,86,35,0.07)';
    ctx.fillRect(PAD.left,yMx,cW,yMn-yMx);
    // SPEC Min line
    ctx.strokeStyle=C_GREEN;ctx.lineWidth=1.5;ctx.setLineDash([6,4]);
    ctx.beginPath();ctx.moveTo(PAD.left,yMn);ctx.lineTo(PAD.left+cW,yMn);ctx.stroke();
    // SPEC Max line
    ctx.strokeStyle=C_ORANGE;ctx.lineWidth=1.5;ctx.setLineDash([6,4]);
    ctx.beginPath();ctx.moveTo(PAD.left,yMx);ctx.lineTo(PAD.left+cW,yMx);ctx.stroke();
    ctx.setLineDash([]);
    // labels
    ctx.font='10px Sarabun,sans-serif';ctx.fillStyle=C_GREEN;ctx.textAlign='left';
    ctx.fillText('Min '+specMin,PAD.left+4,yMn-4);
    ctx.fillStyle=C_ORANGE;
    ctx.fillText('Max '+specMax,PAD.left+4,yMx+12);
  }

  // SV line
  ctx.strokeStyle=C_BLUE;ctx.lineWidth=2;ctx.setLineDash([]);
  ctx.beginPath();
  pts.forEach((p,i)=>{const x=xOf(i),y=yOf(p.sv);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});
  ctx.stroke();

  // Trendline (linear regression)
  if(pts.length>1){
    const n=pts.length;
    let sx=0,sy=0,sxy=0,sx2=0;
    pts.forEach((p,i)=>{sx+=i;sy+=p.sv;sxy+=i*p.sv;sx2+=i*i;});
    const slope=(n*sxy-sx*sy)/(n*sx2-sx*sx);
    const intercept=(sy-slope*sx)/n;
    const ty0=intercept,ty1=slope*(n-1)+intercept;
    ctx.strokeStyle='rgba(193,86,17,0.85)';ctx.lineWidth=2;ctx.setLineDash([8,5]);
    ctx.beginPath();ctx.moveTo(xOf(0),yOf(ty0));ctx.lineTo(xOf(n-1),yOf(ty1));ctx.stroke();
    ctx.setLineDash([]);
  }

  // Dots
  pts.forEach((p,i)=>{
    const x=xOf(i),y=yOf(p.sv);
    const c=p.result==='Pass'?C_GREEN:p.result==='Fail'?C_ORANGE:'#7F6000';
    ctx.beginPath();ctx.arc(x,y,4,0,Math.PI*2);
    ctx.fillStyle=c;ctx.fill();
    ctx.strokeStyle='#fff';ctx.lineWidth=1.5;ctx.stroke();
  });

  // X labels (date/index) — show up to 10
  ctx.fillStyle=C_TEXT;ctx.font='10px Sarabun,sans-serif';ctx.textAlign='center';ctx.setLineDash([]);
  const step=Math.ceil(pts.length/10);
  pts.forEach((p,i)=>{
    if(i%step!==0&&i!==pts.length-1)return;
    const x=xOf(i);
    ctx.fillText(p.date?p.date.slice(5):i+1,x,H-PAD.bottom+14);
  });

  // Tooltip on hover
  canvas._pts=pts;canvas._xOf=xOf;canvas._yOf=yOf;
  canvas._cH=cH;canvas._PAD=PAD;canvas._vmin=vmin;canvas._vmax=vmax;
}

// Hover tooltip
(function(){
  document.addEventListener('DOMContentLoaded',()=>{
    const canvas=document.getElementById('sv-chart');
    if(!canvas)return;
    const tip=document.createElement('div');
    tip.style.cssText='position:fixed;background:#1A2233;color:#fff;padding:6px 10px;border-radius:7px;font-size:11px;line-height:1.6;pointer-events:none;display:none;z-index:9999;box-shadow:0 4px 12px rgba(0,0,0,.2)';
    document.body.appendChild(tip);
    canvas.addEventListener('mousemove',e=>{
      const pts=canvas._pts;if(!pts||!pts.length){tip.style.display='none';return;}
      const rect=canvas.getBoundingClientRect();
      const mx=e.clientX-rect.left;
      const xOf=canvas._xOf;
      let best=0,bd=Infinity;
      pts.forEach((p,i)=>{const d=Math.abs(xOf(i)-mx);if(d<bd){bd=d;best=i;}});
      if(bd>24){tip.style.display='none';return;}
      const p=pts[best];
      const c=p.result==='Pass'?'#4ade80':p.result==='Fail'?'#f87171':'#fbbf24';
      tip.innerHTML=`<b style="color:${c}">${p.result||'—'}</b> | SV: <b>${p.sv}</b><br>
        ${p.label} | ${p.date||''}`;
      tip.style.display='block';
      tip.style.left=(e.clientX+14)+'px';
      tip.style.top=(e.clientY-10)+'px';
    });
    canvas.addEventListener('mouseleave',()=>tip.style.display='none');
  });
})();

