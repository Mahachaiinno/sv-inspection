function renderSpecPage(){
  document.getElementById('spec-tbody').innerHTML=specs.map((s,i)=>`
    <tr>
      <td style="font-weight:700">${s.main}</td>
      <td style="color:var(--text-sec)">${s.sub||'—'}</td>
      <td style="text-align:center"><input class="sinput" type="number" value="${s.min}" onchange="specs[${i}].min=parseFloat(this.value)||0;saveLocal()"></td>
      <td style="text-align:center"><input class="sinput" type="number" value="${s.max}" onchange="specs[${i}].max=parseFloat(this.value)||0;saveLocal()"></td>
      <td style="text-align:center"><button class="btn sm danger" onclick="specs.splice(${i},1);saveLocal();renderSpecPage()"><i class="ti ti-trash"></i></button></td>
    </tr>`).join('');
  const nm=document.getElementById('new-main');
  nm.innerHTML='<option value="">-- เลือก --</option>'+MAIN_FORMULAS.map(f=>`<option>${f}</option>`).join('');
}
function onNMC(){
  const s=SUB_MAP[fget('new-main')]||[];
  document.getElementById('new-sub').innerHTML='<option value="">ทั้งหมด</option>'+s.map(x=>`<option>${x}</option>`).join('');
}
function addSpec(){
  const main=fget('new-main'),sub=fget('new-sub');
  if(!main){toast('กรุณาเลือก Main Formula','err');return;}
  const min=parseFloat(document.getElementById('new-min').value)||0;
  const max=parseFloat(document.getElementById('new-max').value)||0;
  specs.push({main,sub,min,max});saveLocal();renderSpecPage();
  document.getElementById('new-main').value='';
  document.getElementById('new-sub').innerHTML='<option>ทั้งหมด</option>';
  document.getElementById('new-min').value='';document.getElementById('new-max').value='';
  toast('เพิ่ม SPEC แล้ว','ok');
}
async function pushSpec(){
  saveLocal();
  try{await gsCall({action:'saveSpec',specs});toast('บันทึก SPEC → Google Sheet สำเร็จ','ok');}
  catch(e){toast('บันทึก SPEC ล้มเหลว: '+e.message,'err');}
}

