<script>
const GS_URL='https://script.google.com/macros/s/AKfycbyp5RxqIfpq6lZ6D5xp2SoWk9RNBcxzW-Vu7TKjKGT9bNiW1pitF8CPMnzLcWae3-2nXA/exec';
const MAIN_FORMULAS=['701','901','POLY','MS3618','MS9123','TNT','BROODS','NF'];
const SUB_MAP={'701':['P'],'901':['S'],'POLY':['G'],'MS3618':['NK'],'MS9123':['B1'],'TNT':['B2'],'BROODS':['B3'],'NF':[]};
const INSPECTORS=['Inspector 1','Inspector 2','Inspector 3','Inspector 4','Inspector 5','Inspector 6','Inspector 7'];
const SAMP_LIST=[{n:1,l:'Mix1'},{n:2,l:'Mix2'},{n:3,l:'หลังบด'},{n:4,l:'Feeder'},{n:5,l:'Hot Mass'},{n:6,l:'Hot Pallet'},{n:7,l:'HB'},{n:8,l:'Dryer'},{n:9,l:'Cooler'},{n:10,l:'After Sieve'},{n:11,l:'Packing'}];
const LINES=['L1','L2','L3','L4','L5','L6','L7','L8'];
const DEFAULT_SPECS=[{main:'701',sub:'P',min:70,max:110},{main:'901',sub:'S',min:70,max:110},{main:'POLY',sub:'G',min:80,max:120},{main:'MS3618',sub:'NK',min:0,max:0},{main:'MS9123',sub:'B1',min:0,max:0},{main:'TNT',sub:'B2',min:0,max:0},{main:'BROODS',sub:'B3',min:0,max:0},{main:'NF',sub:'',min:0,max:0}];

let records=[],specs=[],selCheckVal='',selSampVal='',rowId=0;
try{const s=localStorage.getItem('sv_r');if(s)records=JSON.parse(s);}catch(e){}
try{const s=localStorage.getItem('sv_s');if(s)specs=JSON.parse(s);else specs=[...DEFAULT_SPECS];}catch(e){specs=[...DEFAULT_SPECS];}

function saveLocal(){try{localStorage.setItem('sv_r',JSON.stringify(records));localStorage.setItem('sv_s',JSON.stringify(specs));}catch(e){}}
function nowDT(){const d=new Date();return{date:d.toISOString().slice(0,10),time:d.toTimeString().slice(0,5)};}
function fget(id){return(document.getElementById(id)||{}).value||'';}
function getSpec(main,sub){return specs.find(s=>s.main===main&&s.sub===sub)||specs.find(s=>s.main===main&&!s.sub)||specs.find(s=>s.main===main)||null;}

async function gsCall(payload){
  const r=await fetch(GS_URL,{method:'POST',body:JSON.stringify(payload)});
  const d=await r.json();
  if(!d.ok)throw new Error(d.error||'GS Error');
  return d;
}

function setConn(state,msg){
  const dot=document.getElementById('cdot'),txt=document.getElementById('ctxt'),btn=document.getElementById('syncbtn');
  dot.className='dot '+(state==='ok'?'dot-ok':state==='err'?'dot-err':'dot-spin');
  txt.textContent=msg;btn.disabled=(state!=='ok');
}

async function autoConnect(){
  setConn('spin','กำลังเชื่อมต่อ...');
  try{await gsCall({action:'getAll'});setConn('ok','Google Sheet พร้อมใช้งาน');syncAll();}
  catch(e){setConn('err','ออฟไลน์ — ใช้ข้อมูล Local');toast('ใช้ข้อมูล Local ('+records.length+' batch)','info');}
}

async function syncAll(){
  const btn=document.getElementById('syncbtn');
  btn.disabled=true;btn.innerHTML='<i class="ti ti-loader-2"></i> Syncing...';
  toast('กำลัง Sync...','info');
  try{
    const res=await gsCall({action:'getAll'});
    const map={};
    (res.records||[]).forEach(r=>{
      const id=String(r['ID']);
      if(!map[id]){map[id]={id,date:r['วันที่'],time:r['เวลา'],inspector:r['Inspector'],shift:r['Shift'],check:r['Check']||'',sampling:r['Sampling'],lot:r['Lot'],remark:r['Remark']||'',rows:[]};}
      if(r['LINE']||r['Main Formula']||r['SV']){map[id].rows.push({line:r['LINE']||'',main:r['Main Formula']||'',sub:r['Sub Formula']||'',feedcode:r['Feed Code']||'',diesize:r['Die Size']||'',sv:r['SV']||'',specMin:r['SPEC Min']||'',specMax:r['SPEC Max']||'',result:r['ผล']||''});}
    });
    records=Object.values(map).sort((a,b)=>Number(b.id)-Number(a.id));
    saveLocal();setConn('ok','Google Sheet พร้อมใช้งาน');
    toast('Sync สำเร็จ — '+records.length+' Batch','ok');
    renderTable();renderDash();
  }catch(e){setConn('err','Sync ล้มเหลว');toast('Sync ล้มเหลว: '+e.message,'err');}
  btn.disabled=false;btn.innerHTML='<i class="ti ti-refresh"></i> Sync';
}

// Sampling
function buildSampPanel(){
  document.getElementById('samp-panel').innerHTML=SAMP_LIST.map(s=>`
    <div class="samp-opt" id="sopt-${s.n}" onclick="selSamp('${s.l}',${s.n})">
      <span class="samp-num">${s.n}.</span>
      <span style="font-size:13px">${s.l}</span>
      <i class="ti ti-check" style="margin-left:auto;font-size:13px;opacity:0" id="sck-${s.n}"></i>
    </div>`).join('');
}
function toggleSampPanel(){document.getElementById('samp-panel').classList.toggle('open');}
function selSamp(label,n){
  selSampVal=label;document.getElementById('f-sampling').value=label;
  document.getElementById('samp-lbl').textContent=n+'. '+label;
  document.getElementById('samp-trigger').classList.add('has-val');
  document.querySelectorAll('.samp-opt').forEach(el=>el.classList.remove('selected'));
  document.querySelectorAll('[id^="sck-"]').forEach(el=>el.style.opacity='0');
  document.getElementById('sopt-'+n).classList.add('selected');
  document.getElementById('sck-'+n).style.opacity='1';
  document.getElementById('samp-panel').classList.remove('open');
}
function clearSamp(){
  selSampVal='';document.getElementById('f-sampling').value='';
  document.getElementById('samp-lbl').textContent='-- เลือก Sampling --';
  document.getElementById('samp-lbl').style.color='var(--text-ter)';
  document.getElementById('samp-trigger').classList.remove('has-val');
  document.querySelectorAll('.samp-opt').forEach(el=>el.classList.remove('selected'));
  document.querySelectorAll('[id^="sck-"]').forEach(el=>el.style.opacity='0');
}
document.addEventListener('click',e=>{if(!document.getElementById('samp-dd').contains(e.target))document.getElementById('samp-panel').classList.remove('open');});

// Check
function selCheck(v){
  selCheckVal=v;
  const ck=document.getElementById('chk-ck'),rc=document.getElementById('chk-rc'),nn=document.getElementById('chk-none');
  ck.className='check-opt';rc.className='check-opt';nn.className='check-opt sel-none';
  if(v==='ตรวจสอบ')ck.className='check-opt sel-ck';
  else if(v==='Recheck')rc.className='check-opt sel-rc';
}

// Nav
function showPage(p,btn){
  document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(x=>x.classList.remove('active'));
  document.getElementById('page-'+p).classList.add('active');
  btn.classList.add('active');
  document.getElementById('samp-panel').classList.remove('open');
  if(p==='records')renderTable();
  if(p==='dash')renderDash();
  if(p==='spec')renderSpecPage();
